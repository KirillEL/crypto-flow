# Root .env — copy to .env and fill in your values

# Backend
PORT=8080
GIN_MODE=release
ALLOWED_ORIGINS=https://your-domain.com

# Telegram Bot (get token from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_NAME=YourBotUsername        # without @, e.g. CryptoFlowBot
TELEGRAM_APP_NAME=app                    # Mini App short name in BotFather
TELEGRAM_WEBHOOK_URL=https://your-domain.com/bot/webhook

# Frontend build args
VITE_API_URL=/api
VITE_WS_URL=wss://stream.binance.com:9443/stream
VITE_TELEGRAM_BOT_NAME=YourBotUsername   # same as TELEGRAM_BOT_NAME
VITE_TELEGRAM_APP_NAME=app               # same as TELEGRAM_APP_NAME
